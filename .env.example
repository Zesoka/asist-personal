# ==============================================================================
# Environment Configuration Example for Asistente - Organizador Familiar
# Rename this file to '.env' and fill in your keys. Do not commit '.env' to git!
# ==============================================================================

# Database path (defaults to SQLite database in backend directory)
# DB_PATH=/app/hub_personal.db

# JWT Secret Key (Use a strong random string in production)
SECRET_KEY=super-secret-hub-personal-key-for-jwt-tokens-2026

# AI Providers API Keys (Optional - mock responses are used as fallback)
GEMINI_API_KEY=
OPENAI_API_KEY=
